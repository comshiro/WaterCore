APP_NAME=WaterCore - weilding Copernicus API
APP_ENV=dev
APP_DEBUG=true
DEFAULT_ALERT_THRESHOLD=0.7
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
COPERNICUS_STAC_URL=https://catalogue.dataspace.copernicus.eu/stac
COPERNICUS_STAC_TIMEOUT_SECONDS=30
COPERNICUS_STAC_TOKEN=
SENTINEL_HUB_BASE_URL=https://services.sentinel-hub.com
SENTINEL_HUB_TOKEN_URL=https://services.sentinel-hub.com/oauth/token
SENTINEL_HUB_PROCESS_PATH=/api/v1/process
SENTINEL_HUB_TIMEOUT_SECONDS=60
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=
CDS_REQUEST_TIMEOUT_SECONDS=300

# Optional push notifications when area transitions to HIGH risk.
# Works with generic webhooks and ntfy topics (e.g., https://ntfy.sh/your-topic).
ALERTS_ENABLED=false
ALERTS_WEBHOOK_URL=
ALERTS_TIMEOUT_SECONDS=10
